[gd_resource type="Resource" script_class="BreedData" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/breeds/breed_data.gd" id="1"]

[resource]
script = ExtResource("1")
model_scene_path = "res://models/dog_golden_retriever.tscn"
fur_material_path = "res://materials/fur_golden_retriever.tres"
breed_name = "Golden Retriever"
breed_group = "Sporting"
description = "The Golden Retriever is one of the most popular breeds worldwide, known for its friendly temperament and beautiful golden double coat. Their water-repellent outer coat and dense, insulating undercoat require regular maintenance but should never be shaved — doing so damages the coat's natural protection against heat, cold, and UV rays. Grooming focuses on thorough brushing, deshedding the undercoat, and neatening the natural feathering on the legs, chest, belly, and tail."
difficulty_tier = 0
unlock_requirement = "available_at_start"
grooming_facts = ["Never shave a Golden Retriever! Their double coat insulates against both heat AND cold — shaving removes this natural temperature regulation.", "Golden Retrievers have a water-repellent outer coat — the natural oils that make it slightly oily are a feature, not something to over-wash.", "The feathering on a Golden's legs, chest, and tail should be trimmed with thinning shears, never clipped, to maintain a natural look.", "Golden Retrievers 'blow' their undercoat twice a year in spring and fall — during these periods, daily brushing is essential.", "An undercoat rake is the single most important tool for Golden Retriever grooming — it removes loose undercoat without damaging the topcoat.", "A high-velocity dryer is used after bathing to blow out loose undercoat — this can remove more dead hair than an hour of brushing.", "The breed standard calls for a 'rich, lustrous golden of various shades' — the coat should look natural and not overly sculpted.", "Golden Retrievers' ears are prone to infections due to their floppy shape — keeping ear hair trimmed improves airflow and reduces moisture.", "Always brush a Golden Retriever thoroughly BEFORE bathing — water turns tangles into concrete-hard mats that must be cut out.", "The feet should be trimmed neatly between the pads and around the edges to give a clean, round 'cat foot' appearance."]
grooming_zones = {"head": {"required_tool": "BRUSH", "guard_size": 0.0, "steps": ["brush_out", "neaten_with_thinning_shears"], "suggested_order": 1, "notes": "Gentle brush and light trimming around ears. No clipping on head."}, "ears_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_ear_edges", "trim_inside_ear"], "suggested_order": 2, "notes": "Thin excess hair around ear edges with thinning shears. Trim inside ear for airflow."}, "ears_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_ear_edges", "trim_inside_ear"], "suggested_order": 3, "notes": "Thin excess hair around ear edges with thinning shears. Trim inside ear for airflow."}, "back": {"required_tool": "BRUSH", "guard_size": 0.0, "steps": ["undercoat_rake", "slicker_brush", "comb_finish"], "suggested_order": 4, "notes": "Thorough undercoat removal with rake, then slicker brush to smooth topcoat."}, "chest": {"required_tool": "BRUSH", "guard_size": 0.0, "steps": ["undercoat_rake", "slicker_brush", "thin_feathering"], "suggested_order": 5, "notes": "Brush out chest ruff. Thin excess feathering with thinning shears for a neat look."}, "belly": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["undercoat_rake", "thin_feathering", "sanitary_trim"], "suggested_order": 8, "notes": "Thin belly feathering for neatness. Sanitary trim for hygiene."}, "legs_front_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_feathering", "trim_feet"], "suggested_order": 6, "notes": "Thin leg feathering with thinning shears. Trim feet to neat round shape."}, "legs_front_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_feathering", "trim_feet"], "suggested_order": 7, "notes": "Thin leg feathering with thinning shears. Trim feet to neat round shape."}, "legs_rear_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_feathering", "trim_hocks", "trim_feet"], "suggested_order": 9, "notes": "Thin rear leg feathering. Neaten hocks. Trim feet round."}, "legs_rear_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_feathering", "trim_hocks", "trim_feet"], "suggested_order": 10, "notes": "Thin rear leg feathering. Neaten hocks. Trim feet round."}, "tail": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "thin_feathering"], "suggested_order": 11, "notes": "Brush plume thoroughly. Thin with thinning shears to a natural flag shape. Never cut blunt."}}
