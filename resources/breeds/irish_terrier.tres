[gd_resource type="Resource" script_class="BreedData" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/breeds/breed_data.gd" id="1"]

[resource]
script = ExtResource("1")
model_scene_path = "res://models/dog_irish_terrier.tscn"
fur_material_path = "res://materials/fur_irish_terrier.tres"
breed_name = "Irish Terrier"
breed_group = "Terrier"
description = "The Irish Terrier is a bold, fiery breed with a dense, wiry red coat that is maintained through hand-stripping — the traditional technique of pulling dead hairs from the topcoat by hand. Each hair has a deep red tip that fades to wheaten at the root, so the coat appears to darken when freshly stripped and lightens as it grows out. The breed standard demands a harsh, flat-lying coat with no softness or woolliness. Irish Terriers are sometimes called the 'Red Devil' for their spirited temperament and striking color."
difficulty_tier = 1
unlock_requirement = "competition_wins_3"
grooming_facts = ["Irish Terriers get a hand-stripped coat because clipping destroys the wiry texture — the coat becomes soft and loses its rich red color over time.", "Each Irish Terrier hair is darkest red at the tip and fades to wheaten at the root — a freshly stripped coat looks darker and deepens in color as it regrows.", "The hand-stripping technique uses 'finger and thumb' — dead hairs are gripped and pulled in the direction they grow, never cut.", "Irish Terriers were the first breed to serve as messenger dogs in World War I, prized for their courage and intelligence.", "The breed standard calls for a flat, harsh coat that lies close to the body — any waviness, curl, or softness is penalized in the show ring.", "A companion Irish Terrier should be fully stripped twice per year, with touch-up stripping every 4-6 weeks to maintain the coat.", "The Irish Terrier's furnishings (beard and leg hair) should be longer than the body coat but kept tidy — the beard frames a strong, rectangular muzzle.", "A stripping knife is held almost parallel to the body — it's used to grip the hair, not cut it. The pulling motion comes from the wrist, not the blade.", "Irish Terriers are one of the oldest terrier breeds — the breed has been documented in Ireland for centuries and was one of the first terrier breeds recognized by the English Kennel Club.", "The correct color is 'whole-coloured' — bright red, golden red, red wheaten, or wheaten. Small white patches on the chest are tolerated but not desired.", "Brush your Irish Terrier weekly with a pin brush to maintain coat texture between stripping sessions — more frequent brushing may be needed during heavy shedding periods.", "After stripping, the new coat takes 8-12 weeks to fully grow back — show dogs are stripped on a rolling schedule to always have some coat at peak condition."]
grooming_zones = {"crown": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["brush_out", "hand_strip_skull", "shape_eyebrows"], "suggested_order": 1, "notes": "Skull hand-stripped flat. Eyebrows tidied but not Schnauzer-dramatic."}, "muzzle": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["scissor_beard", "shape_muzzle"], "suggested_order": 2, "notes": "Beard left longer and scissored to rectangular shape framing the strong muzzle."}, "ears_left": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["hand_strip_ear", "neaten_edges"], "suggested_order": 3, "notes": "Ears stripped short and neat, lying flat against the head. Edges neatened with scissors."}, "ears_right": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["hand_strip_ear", "neaten_edges"], "suggested_order": 4, "notes": "Ears stripped short and neat, lying flat against the head. Edges neatened with scissors."}, "back": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["brush_out", "hand_strip_with_grain", "card_undercoat"], "suggested_order": 5, "notes": "Body coat hand-stripped with the grain. Undercoat carded out to maintain flat lie."}, "chest": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["brush_out", "hand_strip_with_grain", "blend_into_furnishings"], "suggested_order": 6, "notes": "Chest stripped to blend into longer front furnishings. Should appear smooth and flat."}, "belly": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_tidy", "sanitary_trim"], "suggested_order": 10, "notes": "Belly hair tidied with scissors. Sanitary trim for hygiene. Blend into leg furnishings."}, "leg_front_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_furnishings", "trim_feet"], "suggested_order": 7, "notes": "Front leg furnishings left longer and scissored into straight columns. Feet trimmed tight and round."}, "leg_front_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_furnishings", "trim_feet"], "suggested_order": 8, "notes": "Front leg furnishings left longer and scissored into straight columns. Feet trimmed tight and round."}, "leg_rear_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "hand_strip_upper", "scissor_lower", "trim_feet"], "suggested_order": 11, "notes": "Upper rear legs stripped. Lower furnishings scissored. Feet trimmed tight and round."}, "leg_rear_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "hand_strip_upper", "scissor_lower", "trim_feet"], "suggested_order": 12, "notes": "Upper rear legs stripped. Lower furnishings scissored. Feet trimmed tight and round."}, "tail": {"required_tool": "HAND_STRIP", "guard_size": 0.0, "steps": ["hand_strip_with_grain", "scissor_tip"], "suggested_order": 9, "notes": "Tail hand-stripped to lie flat and taper to a point. No feathering or flag."}, "paw_front_left": {"required_tool": "NAIL_TRIMMER", "guard_size": 0.0, "steps": ["trim_nails", "tidy_paw_hair"], "suggested_order": 13, "notes": "Trim nails. Tidy hair between pads. Feet trimmed tight and round."}, "paw_front_right": {"required_tool": "NAIL_TRIMMER", "guard_size": 0.0, "steps": ["trim_nails", "tidy_paw_hair"], "suggested_order": 14, "notes": "Trim nails. Tidy hair between pads. Feet trimmed tight and round."}, "paw_rear_left": {"required_tool": "NAIL_TRIMMER", "guard_size": 0.0, "steps": ["trim_nails", "tidy_paw_hair"], "suggested_order": 15, "notes": "Trim nails. Tidy hair between pads. Feet trimmed tight and round."}, "paw_rear_right": {"required_tool": "NAIL_TRIMMER", "guard_size": 0.0, "steps": ["trim_nails", "tidy_paw_hair"], "suggested_order": 16, "notes": "Trim nails. Tidy hair between pads. Feet trimmed tight and round."}}
