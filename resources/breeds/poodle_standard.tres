[gd_resource type="Resource" script_class="BreedData" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/breeds/breed_data.gd" id="1"]

[resource]
script = ExtResource("1")
model_scene_path = "res://models/dog_poodle_standard.tscn"
fur_material_path = "res://materials/fur_poodle_standard.tres"
breed_name = "Standard Poodle"
breed_group = "Non-Sporting"
description = "The Standard Poodle is one of the most iconic breeds in competitive grooming. Originally bred as a water retriever in Germany, the Poodle's elaborate clips were designed with function in mind — shaved areas reduced drag in water while puffs of hair protected vital joints and organs from cold. Today, the Continental Clip remains the gold standard for show Poodles. Their curly, dense, single-layer coat grows continuously and does not shed, making regular professional grooming essential every 4-6 weeks."
difficulty_tier = 2
unlock_requirement = "available_at_start"
grooming_facts = ["Poodles don't shed — their hair grows continuously like human hair, which is why they need regular haircuts.", "The Continental Clip leaves puffs on the legs to protect joints in cold water — Poodles were originally water retrievers in Germany!", "A #10 blade is standard for shaving the Poodle's face, feet, and base of tail, cutting the hair to about 1/16 inch.", "Poodle hair is actually more like wool — it's curly and dense, forming a single coat rather than the double coat most breeds have.", "The pompons on a show Poodle's hips aren't just decorative — they originally protected the kidney area during cold water retrieves.", "Professional Poodle groomers spend 2-4 hours on a single Continental Clip — it's considered the most technically demanding cut in dog grooming.", "Poodle coats come in over 10 solid colors including black, white, brown, silver, apricot, red, cream, and blue.", "The 'Puppy Clip' is the simpler alternative for pet Poodles — an even length all over the body, much easier to maintain than show clips.", "Poodles must be brushed thoroughly before bathing — water tightens any existing tangles into rock-hard mats that are painful to remove.", "The face shave on a Poodle isn't just aesthetic — it allows the dog clear vision and prevents food from matting in facial hair."]
grooming_zones = {"head": {"required_tool": "CLIPPER", "guard_size": 0.8, "steps": ["brush_out", "clip_face_close", "scissor_topknot"], "suggested_order": 1, "notes": "Face shaved with #10 blade. Topknot left full and scissored into a rounded shape."}, "ears_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_shape"], "suggested_order": 8, "notes": "Ear leather shaved 1/3 from tip. Long ear fringe left and scissored to shape."}, "ears_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_shape"], "suggested_order": 9, "notes": "Ear leather shaved 1/3 from tip. Long ear fringe left and scissored to shape."}, "back": {"required_tool": "CLIPPER", "guard_size": 15.0, "steps": ["brush_out", "clip_with_grain"], "suggested_order": 2, "notes": "Continental: mane area left full, rear shaved with #15 blade. Pack area blended."}, "chest": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "fluff_dry", "scissor_shape"], "suggested_order": 3, "notes": "Mane left full and scissored into rounded shape. This is the hallmark of the Continental."}, "belly": {"required_tool": "CLIPPER", "guard_size": 10.0, "steps": ["brush_out", "clip_with_grain", "sanitary_clip"], "suggested_order": 6, "notes": "Belly shaved close for hygiene. Blended into mane and hip rosettes."}, "legs_front_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "fluff_dry", "scissor_bracelets"], "suggested_order": 4, "notes": "Feet shaved with #10. Puffs left above each foot and scissored round."}, "legs_front_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "fluff_dry", "scissor_bracelets"], "suggested_order": 5, "notes": "Feet shaved with #10. Puffs left above each foot and scissored round."}, "legs_rear_left": {"required_tool": "CLIPPER", "guard_size": 10.0, "steps": ["brush_out", "clip_hindquarters", "scissor_bracelets"], "suggested_order": 7, "notes": "Hindquarters shaved, leaving pompons on hips and bracelets at ankles."}, "legs_rear_right": {"required_tool": "CLIPPER", "guard_size": 10.0, "steps": ["brush_out", "clip_hindquarters", "scissor_bracelets"], "suggested_order": 7, "notes": "Hindquarters shaved, leaving pompons on hips and bracelets at ankles."}, "tail": {"required_tool": "CLIPPER", "guard_size": 10.0, "steps": ["clip_base", "scissor_pompon"], "suggested_order": 10, "notes": "Base of tail shaved with #10. Pompon left at tip and scissored into a round ball."}}
