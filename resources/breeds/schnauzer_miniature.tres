[gd_resource type="Resource" script_class="BreedData" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/breeds/breed_data.gd" id="1"]

[resource]
script = ExtResource("1")
breed_name = "Miniature Schnauzer"
breed_group = "Terrier"
description = "The Miniature Schnauzer is instantly recognizable by its distinguished beard, bushy eyebrows, and crisp body outline. This double-coated breed has a wiry topcoat over a soft undercoat. For show dogs, the topcoat is maintained through hand-stripping — pulling dead hairs by hand to preserve the coat's harsh, wiry texture and vibrant color. Pet Schnauzers are typically clipped, which is faster but gradually softens the coat texture. The breed's iconic facial furnishings require careful scissor work to frame the expression properly."
difficulty_tier = 1
unlock_requirement = "tier_regional"
grooming_facts = ["The Schnauzer's iconic beard isn't just decorative — in the breed's ratting days, the thick facial hair protected their muzzle from bites!", "Hand-stripping pulls dead hairs from the wiry topcoat by hand — it preserves the coat's harsh texture and rich color, unlike clipping which softens it over time.", "A Schnauzer's eyebrows are scissored diagonally from the bridge of the nose toward the outer corner of the eye — this creates their trademark stern expression.", "The #10 blade is the workhorse for Schnauzer grooming — used on the skull, cheeks, throat, and ears, cutting with the grain of the hair.", "The beard and eyebrows should be about 1-2 inches long, while the body coat is trimmed to roughly 1 inch — this contrast defines the breed silhouette.", "Miniature Schnauzers come in four recognized colors: salt and pepper, black, black and silver, and solid white.", "The leg furnishings (the longer hair on the legs) should be brushed daily to prevent matting — they're the most tangle-prone area on the dog.", "A properly groomed Schnauzer should have a rectangular head shape when viewed from the front — the eyebrows and beard create this blocky frame.", "Schnauzers need grooming every 4-6 weeks to maintain their distinctive outline — the body coat grows out quickly and loses its crisp shape.", "The ears are clipped very short with a #30 or #40 blade on the inside and outside, making them appear small and neat against the head."]
grooming_zones = {"head": {"required_tool": "CLIPPER", "guard_size": 1.6, "steps": ["brush_out", "clip_skull", "clip_cheeks", "scissor_eyebrows"], "suggested_order": 1, "notes": "#10 blade on skull and cheeks with the grain. Eyebrows scissored diagonally — inner corner short, outer corner long."}, "ears_left": {"required_tool": "CLIPPER", "guard_size": 0.5, "steps": ["clip_inside", "clip_outside", "neaten_edges"], "suggested_order": 2, "notes": "#30 or #40 blade on ear leather inside and out. Edges neatened with scissors."}, "ears_right": {"required_tool": "CLIPPER", "guard_size": 0.5, "steps": ["clip_inside", "clip_outside", "neaten_edges"], "suggested_order": 3, "notes": "#30 or #40 blade on ear leather inside and out. Edges neatened with scissors."}, "back": {"required_tool": "CLIPPER", "guard_size": 3.2, "steps": ["brush_out", "clip_with_grain", "blend_skirt"], "suggested_order": 4, "notes": "#7F or #10 blade on body with the grain. Blend into longer skirt furnishings."}, "chest": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "clip_throat", "scissor_chest_furnishings"], "suggested_order": 5, "notes": "Throat clipped with #10. Chest furnishings left longer and scissored to blend into skirt."}, "belly": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_skirt", "sanitary_trim"], "suggested_order": 8, "notes": "Skirt (the longer belly fringe) scissored to a clean line. Sanitary area clipped short."}, "legs_front_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_columns", "trim_feet"], "suggested_order": 6, "notes": "Leg furnishings brushed out fully and scissored into straight columns. Feet trimmed round."}, "legs_front_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_columns", "trim_feet"], "suggested_order": 7, "notes": "Leg furnishings brushed out fully and scissored into straight columns. Feet trimmed round."}, "legs_rear_left": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_columns", "trim_feet"], "suggested_order": 9, "notes": "Rear leg furnishings scissored into straight columns blending into body clip."}, "legs_rear_right": {"required_tool": "SCISSORS", "guard_size": 0.0, "steps": ["brush_out", "scissor_columns", "trim_feet"], "suggested_order": 10, "notes": "Rear leg furnishings scissored into straight columns blending into body clip."}, "tail": {"required_tool": "CLIPPER", "guard_size": 1.6, "steps": ["clip_with_grain", "scissor_tip"], "suggested_order": 11, "notes": "Tail clipped with #10 blade with the grain. Tip neatened with scissors. Docked tails traditional but not required."}}
