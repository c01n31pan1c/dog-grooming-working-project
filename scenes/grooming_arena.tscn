[gd_scene load_steps=8 format=3 uid="uid://grooming_arena_001"]

[ext_resource type="Script" path="res://scripts/ui/grooming_arena_screen.gd" id="1"]
[ext_resource type="PackedScene" uid="uid://dog_placeholder_001" path="res://models/dog_placeholder.tscn" id="2"]
[ext_resource type="Script" path="res://scripts/grooming/orbit_camera.gd" id="3"]
[ext_resource type="Script" path="res://scripts/grooming/zone_detection.gd" id="4"]

[sub_resource type="Environment" id="Environment_1"]
background_mode = 1
background_color = Color(0.831, 0.914, 0.969, 1.0)
ambient_light_source = 2
ambient_light_color = Color(0.85, 0.9, 0.95, 1)
ambient_light_energy = 0.8
tonemap_mode = 2

[sub_resource type="PlaneMesh" id="PlaneMesh_ground"]
size = Vector2(8, 8)

[sub_resource type="StandardMaterial3D" id="GroundMaterial"]
albedo_color = Color(0.88, 0.92, 0.95, 1)
roughness = 0.85

[node name="GroomingArena" type="Node"]
script = ExtResource("1")

;; === 3D VIEWPORT (SubViewport for the dog scene) ===
[node name="SubViewportContainer" type="SubViewportContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
stretch = true

[node name="SubViewport" type="SubViewport" parent="SubViewportContainer"]
handle_input_locally = false
physics_object_picking = true
size = Vector2i(1920, 1080)
render_target_update_mode = 4

[node name="DogScene" type="Node3D" parent="SubViewportContainer/SubViewport"]

;; World environment
[node name="WorldEnvironment" type="WorldEnvironment" parent="SubViewportContainer/SubViewport/DogScene"]
environment = SubResource("Environment_1")

;; Dog model instance
[node name="DogPlaceholder" type="Node3D" parent="SubViewportContainer/SubViewport/DogScene" instance=ExtResource("2")]

;; Orbit camera
[node name="OrbitCamera" type="Camera3D" parent="SubViewportContainer/SubViewport/DogScene"]
script = ExtResource("3")
transform = Transform3D(1, 0, 0, 0, 0.82, 0.57, 0, -0.57, 0.82, 0, 1.7, 2.5)
current = true
fov = 45.0
target = Vector3(0, 0.5, 0)
distance = 3.0
min_distance = 1.5
max_distance = 6.0

;; === 3-POINT LIGHTING ===
;; Key light (warm, main shadow caster)
[node name="KeyLight" type="DirectionalLight3D" parent="SubViewportContainer/SubViewport/DogScene"]
transform = Transform3D(0.866, -0.25, 0.433, 0, 0.866, 0.5, -0.5, -0.433, 0.75, 2, 3, 2)
light_color = Color(1, 0.97, 0.92, 1)
light_energy = 1.4
shadow_enabled = true

;; Fill light (cool, softer, opposite side)
[node name="FillLight" type="DirectionalLight3D" parent="SubViewportContainer/SubViewport/DogScene"]
transform = Transform3D(0.866, 0.25, -0.433, 0, 0.866, 0.5, 0.5, -0.433, 0.75, -2, 2, 1)
light_color = Color(0.9, 0.94, 1, 1)
light_energy = 0.6
shadow_enabled = false

;; Rim/back light (highlights edges)
[node name="RimLight" type="DirectionalLight3D" parent="SubViewportContainer/SubViewport/DogScene"]
transform = Transform3D(1, 0, 0, 0, 0.866, -0.5, 0, 0.5, 0.866, 0, 2, -3)
light_color = Color(1.0, 0.98, 0.95, 1)
light_energy = 0.8
shadow_enabled = false

;; Ground plane
[node name="GroundPlane" type="MeshInstance3D" parent="SubViewportContainer/SubViewport/DogScene"]
mesh = SubResource("PlaneMesh_ground")
material_override = SubResource("GroundMaterial")
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0)

;; === ZONE DETECTION ===
[node name="ZoneDetection" type="Node" parent="."]
script = ExtResource("4")

;; === UI OVERLAY ===
[node name="UI" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

;; Zone label (hidden, kept for signal compatibility)
[node name="ZoneLabel" type="Label" parent="UI"]
layout_mode = 1
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -200.0
offset_top = -30.0
offset_right = 200.0
visible = false
text = ""
horizontal_alignment = 1

