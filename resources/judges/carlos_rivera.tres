script = ExtResource("1")
judge_name = "Carlos Rivera"
personality = "A flamboyant showman who believes grooming is an art form. Carlos loves bold presentation, creative flair, and dogs that strut onto the stage looking like they own it. He is forgiving of minor technical imperfections if the overall look is stunning."
